---
import BaseLayout from '../layouts/BaseLayout.astro';

// Contact links — edit these. LinkedIn is a placeholder until you add yours.
const contact = {
  email: 'ajmlee28@gmail.com',
  github: 'https://github.com/AldenLee28',
  linkedin: 'https://www.linkedin.com/in/your-handle',
};
---

<BaseLayout title="Alden Lee — Developer Portfolio">
  <section class="hero glass-panel">
    <!-- Drop a photo at public/images/profile.jpg to replace the initials avatar. -->
    <div class="avatar" aria-hidden="true">AL</div>
    <div class="intro">
      <h1>Hi, I'm Alden</h1>
      <p>
        I'm a year-3 Information Systems student at HKUST, building
        quantitative-finance tooling — valuation engines, systematic trading
        bots, and data pipelines. Based in North Point, Hong Kong.
      </p>
      <p class="cta"><a class="glass-button" href="/portfolio/">View my work →</a></p>
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <ul class="links">
      <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
      <li><a href={contact.github}>GitHub</a></li>
      <li><a href={contact.linkedin}>LinkedIn</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl);
  }
  .avatar {
    flex: none;
    width: 6rem;
    height: 6rem;
    border-radius: var(--radius-full);
    display: grid;
    place-items: center;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-inverse);
    background: var(--color-accent);
  }
  .intro {
    flex: 1;
    min-width: 15rem;
  }
  .intro h1 {
    margin-top: 0;
  }
  .intro p {
    color: var(--color-text-muted);
    max-width: 38rem;
  }
  .cta a {
    text-decoration: none;
    color: var(--color-text);
  }
  .links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }
</style>
