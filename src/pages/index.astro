---
import BaseLayout from '../layouts/BaseLayout.astro';

// Contact links — edit these. LinkedIn is a placeholder until you add yours.
const contact = {
  email: 'ajmlee28@gmail.com',
  github: 'https://github.com/AldenLee28',
  linkedin: 'https://www.linkedin.com/in/your-handle',
};
---

<BaseLayout title="Alden Lee — Developer Portfolio">
  <section class="hero glass-panel">
    <!-- Shows public/images/profile.jpg once you add it; falls back to the
         "AL" initials avatar if the file is missing. -->
    <div class="avatar">
      <img src="/images/profile.jpg" alt="Alden Lee" onerror="this.remove()" />
      <span class="initials" aria-hidden="true">AL</span>
    </div>
    <div class="intro">
      <h1>Hi, I'm Alden</h1>
      <p>
        I'm a year-3 Information Systems student at HKUST, building
        quantitative-finance tooling — valuation engines, systematic trading
        bots, and data pipelines. Based in North Point, Hong Kong.
      </p>
      <p class="cta"><a class="glass-button" href="/portfolio/">View my work →</a></p>
    </div>
  </section>

  <section id="contact">
    <h2>Contact Me</h2>
    <p class="lead">Feel free to reach out — I'm open to internships and collaboration.</p>
    <div class="links">
      <a class="glass-button" href={`mailto:${contact.email}`}>✉ Email</a>
      <a class="glass-button" href={contact.github}>GitHub</a>
      <a class="glass-button" href={contact.linkedin}>LinkedIn</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl);
  }
  .avatar {
    position: relative;
    flex: none;
    width: 6rem;
    height: 6rem;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--color-accent);
  }
  .avatar img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }
  /* Sits behind the photo; visible only when the <img> removes itself. */
  .initials {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-inverse);
  }
  .intro {
    flex: 1;
    min-width: 15rem;
  }
  .intro h1 {
    margin-top: 0;
  }
  .intro p {
    color: var(--color-text-muted);
    max-width: 38rem;
  }
  .cta a {
    text-decoration: none;
    color: var(--color-text);
  }
  #contact .lead {
    color: var(--color-text-muted);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
  .links a {
    text-decoration: none;
    color: var(--color-text);
  }
</style>
