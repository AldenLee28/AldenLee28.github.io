---
import BaseLayout from '../layouts/BaseLayout.astro';

// Displays public/resume.pdf inline. Drop your résumé there as `resume.pdf`.
const resumeUrl = '/resume.pdf';
---

<BaseLayout title="Resume — Alden Lee">
  <div class="head">
    <h1>Resume</h1>
    <a class="glass-button" href={resumeUrl} download>Download PDF ↓</a>
  </div>

  <object class="preview glass-panel" data={resumeUrl} type="application/pdf">
    <p class="fallback">
      Your browser can't display the PDF inline.
      <a href={resumeUrl}>Open or download the resume</a> instead.
      <br />
      <small>(If nothing loads, add your résumé as <code>public/resume.pdf</code>.)</small>
    </p>
  </object>
</BaseLayout>

<style>
  .head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .head a {
    text-decoration: none;
    color: var(--color-text);
  }
  .preview {
    display: block;
    width: 100%;
    height: 80vh;
    margin-top: var(--space-lg);
    border: 1px solid var(--glass-border);
  }
  .fallback {
    padding: var(--space-lg);
    color: var(--color-text-muted);
  }
</style>
