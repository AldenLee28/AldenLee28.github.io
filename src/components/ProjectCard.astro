---
interface Props {
  id: string;
  title: string;
  blurb: string;
  tags: string[];
  wip?: boolean;
}

const { id, title, blurb, tags, wip = false } = Astro.props;
---

<a class="glass-card card" href={`/projects/${id}/`}>
  <h3>
    {title}
    {wip && <span class="wip">WIP</span>}
  </h3>
  <p>{blurb}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((t) => <span>{t}</span>)}
    </div>
  )}
</a>

<style>
  .card {
    display: block;
    padding: var(--space-lg);
    text-decoration: none;
    color: var(--color-text);
  }
  .card:hover {
    text-decoration: none;
  }
  h3 {
    margin: 0 0 0.4em;
    font-size: var(--text-lg);
    color: var(--color-accent-text);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }
  .wip {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    padding: 0.05em 0.6em;
  }
  p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .tags {
    margin-top: var(--space-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .tags span {
    font-size: var(--text-xs);
    color: var(--color-accent-text);
    background: var(--color-accent-glass);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    padding: 0.1em 0.7em;
  }
</style>
